rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Assuming role is set in custom claims by the backend
      return isAuthenticated() && request.auth.token.role == 'admin';
    }

    function isLoanOfficer() {
      return isAuthenticated() && request.auth.token.role == 'loan_officer';
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users Collection
    match /users/{userId} {
      // Users can read/write their own profile
      allow read, write: if isOwner(userId) || isAdmin();
      // Loan officers can read user profiles
      allow read: if isLoanOfficer();
    }

    // Shops Collection
    match /shops/{shopId} {
      // Shop owners can read/write their own shops
      allow read: if isAuthenticated() && (resource.data.owner_id == request.auth.uid || isAdmin() || isLoanOfficer());
      allow create: if isAuthenticated() && request.resource.data.owner_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.owner_id == request.auth.uid || isAdmin());
    }

    // Applications Collection
    match /applications/{applicationId} {
      // Shop owners can read/write their own applications
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isAdmin() || isLoanOfficer());
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isAdmin() || isLoanOfficer());
      allow delete: if isAdmin();
    }

    // Admin & System Collections (Backend Managed)
    // We explicitly restrict these to Admin read-only on the client side, 
    // as all write operations are securely managed by the FastAPI backend.
    
    match /admin_notifications/{notificationId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /demo_requests/{requestId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
